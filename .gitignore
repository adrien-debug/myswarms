# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# setup-adrien (secrets projet)
docs/api-config/
.supabase-db-password.tmp

# electron
dist-electron/
out/
electron/__tests__/screenshots/
electron/__tests__/results/
*.dmg
*.exe
*.AppImage
*.deb

# Electron build output (lourd — ne pas committer, régénéré via npm run electron:build)
dist/
*.blockmap
dist/builder-debug.yml

# Rapports d'audit générés (squad/ready/all)
docs/audit/

# Python
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
services/*/.venv/

# Python build artifacts
**/*.egg-info/

# Claude Code (config locale — settings, plans, worktrees)
.claude/
.playwright-mcp/
login-with-nav.png

# Archive front Next.js (lourd — dist/ 21 GB, node_modules)
.archive/**/node_modules/
.archive/**/dist/
.archive/**/.next/
docs/api-config/SERVICES.md
docs/credentials.local.txt
.hedge-admin-*.tmp
.env.hedge
