{
  "name": "myswarms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3333",
    "build": "next build",
    "start": "next start -p 3333",
    "lint": "eslint",
    "test": "vitest run",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:3333 && npm run electron:start\"",
    "electron:assets": "mkdir -p dist-electron && cp electron/splash.html dist-electron/splash.html",
    "electron:start": "tsc -p electron && npm run electron:assets && electron .",
    "electron:build": "tsc -p electron && npm run electron:assets && electron-builder",
    "electron:test": "playwright test electron/__tests__",
    "electron:publish": "tsc -p electron && npm run electron:assets && electron-builder --publish always"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.10.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "next": "16.2.6",
    "openai": "^6.38.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.6",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.10"
  },
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.myswarms.desktop",
    "productName": "MySwarms",
    "files": [
      "dist-electron/**/*",
      ".next/**/*",
      "public/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "notarize": false
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "publish": null
  }
}
